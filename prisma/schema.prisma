generator client {
  provider = "prisma-client"
  output   = "../src/generated"
}

datasource db {
  provider = "mysql"
}

model calendar {
  id                   Int                    @id @default(autoincrement())
  tipo_calendar        calendar_tipo_calendar @default(PRIVADO)
  user_id              String?                @db.Char(8)
  name                 String                 @db.VarChar(120)
  color                String?                @default("#ffffff") @db.VarChar(20)
  is_activo            Boolean?               @default(true)
  created_at           DateTime?              @default(now()) @db.Timestamp(0)
  subdireccion_dpto_id Int?
  event                event[]
  event_fijo           event_fijo[]
}

model event {
  id_event           Int        @id @default(autoincrement())
  calendar_id        Int
  tipo_event_id      Int
  title              String     @db.VarChar(200)
  description        String?    @db.Text
  oficina            String?    @db.VarChar(200)
  start              DateTime   @db.DateTime(0)
  end                DateTime   @db.DateTime(0)
  user_id            String     @db.Char(8)
  all_day            Boolean?   @default(false)
  created_at         DateTime?  @default(now()) @db.Timestamp(0)
  updated_at         DateTime?  @default(now()) @db.Timestamp(0)
  user_created_event String?    @db.VarChar(255)
  is_active          Boolean?   @default(dbgenerated("(true)"))
  calendar           calendar   @relation(fields: [calendar_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "event_ibfk_1")
  tipo_event         tipo_event @relation(fields: [tipo_event_id], references: [id_tipo_event], onDelete: NoAction, onUpdate: NoAction, map: "tipo_event_ibfk_1")

  @@index([calendar_id], map: "calendar_id")
  @@index([tipo_event_id], map: "tipo_event_id")
}

model tipo_event {
  id_tipo_event Int                    @id @default(autoincrement())
  nombre        String                 @db.VarChar(50)
  descripcion   String?                @db.Text
  tipo_evento   tipo_event_tipo_evento @default(EVENTO)
  color_hex     String?                @default("#ffffff") @db.VarChar(20)
  img_url       String?                @db.Text
  icono_url     String?                @db.Text
  created_at    DateTime?              @default(now()) @db.Timestamp(0)
  updated_at    DateTime?              @default(now()) @db.Timestamp(0)
  is_active     Boolean?               @default(dbgenerated("(true)"))
  event         event[]
  event_fijo    event_fijo[]
  events        events[]
}

model event_fijo {
  id_event_fijo Int        @id @default(autoincrement())
  calendar_id   Int
  title         String     @db.VarChar(200)
  description   String?    @db.Text
  month         Int
  day           Int
  tipo_event_id Int
  created_at    DateTime?  @default(now()) @db.Timestamp(0)
  updated_at    DateTime?  @default(now()) @db.Timestamp(0)
  is_active     Boolean?   @default(dbgenerated("(true)"))
  calendar      calendar   @relation(fields: [calendar_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "event_fijo_ibfk_1")
  tipo_event    tipo_event @relation(fields: [tipo_event_id], references: [id_tipo_event], onDelete: Cascade, onUpdate: NoAction, map: "event_fijo_ibfk_2")

  @@index([calendar_id], map: "calendar_id")
  @@index([tipo_event_id], map: "tipo_event_id")
}

model events {
  id_event          Int               @id @default(autoincrement())
  title             String            @db.VarChar(150)
  description       String?           @db.Text
  oficina           String?           @db.VarChar(200)
  type_event_id     Int
  start             DateTime          @db.DateTime(0)
  end               DateTime          @db.DateTime(0)
  all_day           Boolean?          @default(false)
  visibility        events_visibility
  name_user_created String?           @db.VarChar(255)
  user_created_id   String            @db.Char(8)
  group_id          Int?
  is_active         Boolean?          @default(dbgenerated("(true)"))
  created_at        DateTime?         @default(now()) @db.Timestamp(0)
  updated_at        DateTime?         @default(now()) @db.Timestamp(0)
  tipo_event        tipo_event        @relation(fields: [type_event_id], references: [id_tipo_event], onDelete: NoAction, onUpdate: NoAction, map: "type_event_ibfk_1")

  @@index([type_event_id], map: "type_event_ibfk_1")
}

enum calendar_tipo_calendar {
  PUBLICO
  GRUPO
  PRIVADO
}

enum tipo_event_tipo_evento {
  FIJO
  EVENTO
}

enum events_visibility {
  PUBLIC
  GROUP
  PRIVATE
}
